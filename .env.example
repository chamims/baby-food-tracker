# Google AI (Gemini) API key — powers AI food analysis and photo recognition (optional)
# Free tier: 1,500 requests/day — get yours at https://aistudio.google.com/apikey
# Without this key the app works normally with no AI features shown.
VITE_GOOGLE_AI_API_KEY=your_api_key_here

# Supabase — enables cross-device data persistence (optional; falls back to localStorage)
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
